# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Google Calendar API
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Analytics (optional)
NEXT_PUBLIC_ANALYTICS_ID=

# Chiave di cifratura AES-256-GCM (riusabile per più integrazioni)
# Usata per cifrare credenziali sensibili (es. KEROS) prima di salvarle su Supabase.
#
# Genera una chiave sicura con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# ⚠️  Senza questa chiave le integrazioni cifrate non funzionano.
# ⚠️  Non cambiare questa chiave dopo aver salvato credenziali cifrate
#      (i valori diventerebbero illeggibili — riconfigura da UI).
ENCRYPTION_KEY=genera_una_chiave_hex_64_caratteri_con_il_comando_sopra
